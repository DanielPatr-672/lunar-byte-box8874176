modules = ["nodejs-20"]
[agent]
expertMode = true
integrations = ["javascript_anthropic_ai_integrations:2.0.0", "javascript_gemini_ai_integrations:2.0.0", "javascript_openai_ai_integrations:2.0.0", "javascript_openrouter_ai_integrations:2.0.0"]

[userenv]

[userenv.shared]
PROXY_SECRET = "baihe"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node app.mjs"

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 3000
externalPort = 80

[nix]
channel = "stable-25_05"

[deployment]
deploymentTarget = "cloudrun"
run = ["sh", "-c", "node app.mjs"]
